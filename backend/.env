# ===========================================
# GLEPS CRM Backend - Development Environment
# ===========================================

# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# Database (PostgreSQL)
DATABASE_URL=postgresql://gleps:gleps_secret@localhost:5432/gleps_crm?schema=public

# JWT Authentication
JWT_SECRET=dev-jwt-secret-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-in-production-min-32
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Chatwoot Integration (Optional)
CHATWOOT_WEBHOOK_SECRET=

# Google Calendar OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# Logging
LOG_LEVEL=debug
