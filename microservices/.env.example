# ===========================================
# GLEPS CRM Microservices - Environment Variables
# ===========================================

# Database
POSTGRES_USER=gleps
POSTGRES_PASSWORD=gleps_secret
POSTGRES_DB=gleps_crm

# JWT (IMPORTANT: Generate secure keys in production!)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-characters

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:8080

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:8080

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
