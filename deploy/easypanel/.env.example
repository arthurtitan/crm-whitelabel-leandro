# ============================================
# GLEPS CRM - Variáveis de Ambiente (EasyPanel)
# ============================================
# Configure TODAS as variáveis abaixo no painel do EasyPanel.
# Variáveis marcadas com [OBRIGATÓRIO] devem ser preenchidas.
# Variáveis marcadas com [OPCIONAL] podem ser deixadas vazias.
# ============================================

# ---- Banco de Dados [OBRIGATÓRIO] ----
DB_USER=gleps
DB_PASSWORD=TROQUE_PARA_SENHA_FORTE_AQUI
DB_NAME=gleps_crm

# ---- URLs [OBRIGATÓRIO] ----
# FRONTEND_URL: URL pública onde o app será acessado (com https)
FRONTEND_URL=https://360.seudominio.com.br

# API_URL: URL interna do backend (geralmente não precisa mudar)
API_URL=http://backend:3000

# ---- CORS [RECOMENDADO] ----
# Lista de origens permitidas, separadas por vírgula.
# Se vazio, usa FRONTEND_URL como única origem permitida.
CORS_ORIGINS=https://360.seudominio.com.br

# ---- JWT [OBRIGATÓRIO] ----
# Gere com: openssl rand -base64 32
JWT_SECRET=TROQUE_PARA_CHAVE_SEGURA_MIN_32_CHARS
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=TROQUE_PARA_OUTRA_CHAVE_SEGURA_MIN_32
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Segurança ----
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Rede interna [OPCIONAL] ----
# Nome do serviço backend na rede Docker do EasyPanel.
# Só altere se o EasyPanel renomear o serviço.
BACKEND_UPSTREAM=backend:3000

# ---- Seed [OPCIONAL] ----
# Desative após primeiro deploy bem-sucedido para evitar re-execução.
RUN_SEED=true

# ---- Chatwoot [OPCIONAL] ----
CHATWOOT_WEBHOOK_SECRET=

# ---- Google Calendar [OPCIONAL] ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://360.seudominio.com.br/api/calendar/google/callback

# ---- Logging ----
LOG_LEVEL=info
